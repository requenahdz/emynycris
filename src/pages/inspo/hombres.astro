---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Inspo Hombres">
  <main class="relative min-h-screen w-full overflow-hidden flex items-center justify-center px-4 py-10">
    <div
      class="absolute inset-0"
      style="background-image:url(/assets/images/fondo-2.png);background-repeat:repeat;background-size:720px auto;"
    ></div>

    <div class="relative z-10 w-full max-w-[1100px]">
           <div class="flex items-center justify-center gap-6">
        <img src="/assets/images/rosa1.png" alt="" class="w-20 md:w-24 h-auto opacity-70" />
        <h1 class="text-center font-serif text-[40px] md:text-[56px] tracking-[0.16em] text-[#3b3531]">INSPO</h1>
        <img src="/assets/images/rosa2.png" alt="" class="w-20 md:w-24 h-auto opacity-70" />
      </div>

      <p class="mt-4 mx-auto max-w-[820px] text-center font-serif text-[13px] md:text-[15px] leading-relaxed text-[#3b3531]/85">
        Traje formal completo. 
      </p>

      <img src="/assets/images/inspo-hombres.png" alt="Inspiración hombres" class="mt-6 w-full h-auto" />
    </div>
  </main>
</BaseLayout>

